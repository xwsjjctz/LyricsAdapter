{
  "name": "lyrics-adapter",
  "private": true,
  "version": "0.1.3",
  "type": "module",
  "main": "dist-electron/main.js",
  "author": "xwsjjctz",
  "license": "MIT",
  "description": "一款能解析音频内嵌歌词且挺好看的离线本地音乐播放器",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "vite --mode development",
    "electron:build": "npm run build && cross-env NODE_OPTIONS=--no-deprecation electron-builder",
    "electron:build:win": "npm run build && cross-env NODE_OPTIONS=--no-deprecation electron-builder --win --x64",
    "electron:build:win:arm64": "npm run build && cross-env NODE_OPTIONS=--no-deprecation electron-builder --win --arm64",
    "electron:build:mac": "npm run build && cross-env NODE_OPTIONS=--no-deprecation electron-builder --mac",
    "electron:build:mac:dev": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false NODE_OPTIONS=--no-deprecation electron-builder --mac --dir",
    "electron:build:linux": "npm run build && cross-env NODE_OPTIONS=--no-deprecation electron-builder --linux",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "flac-metadata": "^0.1.1",
    "idb": "^8.0.3",
    "music-metadata": "^11.11.0",
    "node-id3": "^0.2.9",
    "probe-image-size": "^7.2.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "cross-env": "^7.0.3",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^25.0.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^3.2.6"
  },
  "build": {
    "appId": "com.lyricsadapter.app",
    "productName": "LyricsAdapter",
    "directories": {
      "output": "release"
    },
    "icon": "app-icon.png",
    "compression": "maximum",
    "files": [
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "dist",
        "to": "dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "binaries",
        "to": "binaries",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "afterPack": "scripts/cleanLocales.cjs",
    "publish": {
      "provider": "github",
      "owner": "xwsjjctz",
      "repo": "LyricsAdapter"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "differentialPackage": true
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.music",
      "hardenedRuntime": false
    },
    "dmg": {
      "writeUpdateInfo": false
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
